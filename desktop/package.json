{
  "name": "kyrozen-desktop",
  "version": "0.1.0",
  "type": "module",
  "description": "Kyrozen desktop client for local agent execution",
  "main": "dist-electron/main/main.js",
  "homepage": ".",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "fix-electron": "node scripts/postinstall.js",
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.kyrozen.desktop",
    "productName": "Kyrozen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "protocols": [
      {
        "name": "Kyrozen Protocol",
        "schemes": [
          "kyrozen"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "kyrozen",
      "repo": "kyrozen",
      "releaseType": "release"
    }
  }
}
